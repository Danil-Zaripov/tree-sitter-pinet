{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "pinet",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "stmt"
      }
    },
    "ident": {
      "type": "PATTERN",
      "value": "[[:alpha:]][a-zA-Z0-9']*"
    },
    "name": {
      "type": "ALIAS",
      "content": {
        "type": "SYMBOL",
        "name": "ident"
      },
      "named": false,
      "value": "name"
    },
    "agent": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "ident"
        },
        {
          "type": "STRING",
          "value": "("
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "arg_list"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": ")"
        }
      ]
    },
    "value": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "name"
        },
        {
          "type": "SYMBOL",
          "name": "agent"
        }
      ]
    },
    "arg_list": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "value"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "STRING",
                "value": ","
              },
              {
                "type": "SYMBOL",
                "name": "value"
              }
            ]
          }
        }
      ]
    },
    "active_pair": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "value"
        },
        {
          "type": "STRING",
          "value": "~"
        },
        {
          "type": "SYMBOL",
          "name": "value"
        }
      ]
    },
    "aplist": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "active_pair"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "STRING",
                "value": ","
              },
              {
                "type": "SYMBOL",
                "name": "active_pair"
              }
            ]
          }
        }
      ]
    },
    "rule": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "value"
        },
        {
          "type": "STRING",
          "value": "><"
        },
        {
          "type": "SYMBOL",
          "name": "value"
        },
        {
          "type": "STRING",
          "value": "=>"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "aplist"
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "print_stmt": {
      "type": "SYMBOL",
      "name": "name"
    },
    "stmt": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "aplist"
            },
            {
              "type": "SYMBOL",
              "name": "rule"
            },
            {
              "type": "SYMBOL",
              "name": "print_stmt"
            }
          ]
        },
        {
          "type": "STRING",
          "value": ";"
        }
      ]
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}